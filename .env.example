# LLM provider configuration. The endpoint is OpenAI-compatible.
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.vectorengine.cn/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1

# LangSmith / LangChain tracing.
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=SORA

# Local MCP tool server. Nodes try MCP first, then fall back to local tools.
MCP_ENABLED=true
MCP_SERVER_COMMAND=python
MCP_SERVER_ARGS=mcp_server.py
MCP_TIMEOUT_SECONDS=8
